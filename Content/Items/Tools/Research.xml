        <Price storeidentifier="merchantmine" sold="false" />
        <Price storeidentifier="merchantbutcher" minavailable="2" maxavailable="3" />
      </Price>
      <Deconstruct time="20">
        <Item identifier="carbon" />
      </Deconstruct>
      <InventoryIcon texture="%ModDir:2954998725%/Content/Items/Tools/Tools.png" sourcerect="904,860,120,164" origin="0.5,0.5" />
      <Sprite texture="%ModDir:2954998725%/Content/Items/Tools/Tools.png" sourcerect="707,998,75,12" depth="0.6" origin="0.5,0.5" />
      <Body width="75" height="12" density="8" />
      <Holdable slots="Any,RightHand+LeftHand" aimable="false" aimpos="40,10" handle1="5,0" aimangle="80" swingamount="0,3" swingspeed="0.5" swingwhenaiming="true" msg="ItemMsgPickUpSelect">
        <StatusEffect type="OnSecondaryUse" target="This" Condition="-10" />
        <!-- give some more skill if low skill -->
        <StatusEffect type="OnSecondaryUse" target="This,Character" disabledeltatime="true" oneshot="true" comparison="and" >
          <Conditional Condition="lte 0" />
          <Conditional skillrequirement="true" cooking="lt 20" />
          <Conditional skillrequirement="true" butchery="lt 20" />
          <GiveSkill skillidentifier="cooking" amount="2" triggertalents="false" />
          <GiveSkill skillidentifier="butchery" amount="2" triggertalents="false" />
        </StatusEffect>
        <StatusEffect type="OnSecondaryUse" target="This,Character" disabledeltatime="true" oneshot="true" >
          <Conditional Condition="lte 0" />
          <GiveSkill skillidentifier="cooking" amount="3" triggertalents="false" />
          <GiveSkill skillidentifier="butchery" amount="3" triggertalents="false" />
          <ReduceAffliction type="mood" amount="25" />
        </StatusEffect>
        <StatusEffect type="OnBroken" target="This" >
          <RemoveItem />
        </StatusEffect>
      </Holdable>
    </Item>
    
