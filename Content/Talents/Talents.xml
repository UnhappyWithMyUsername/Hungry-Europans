  <Override>
    <Talent identifier="he-hungryeuropan">
      <Icon texture="%ModDir:2954998725%/Content/UI/HE-IconsAtlas.png" sourcerect="0,385,119,119" origin="0.5,0.5"/>
      <Description tag="talentdescription.he-hungryeuropan" />
      <AbilityGroupInterval interval="1.0">
        <Abilities>
          <CharacterAbilityApplyStatusEffects>
            <StatusEffects>
              <StatusEffect type="OnAbility" target="Character" disabledeltatime="true" multiplyafflictionsbymaxvitality="true">
                <Conditional IsBot="false" />
                <Affliction identifier="hunger" strength="0.01"/>
                <!-- <Affliction identifier="hungerfoodbuffresistance" strength="0.01"/> -->
              </StatusEffect>
              <StatusEffect type="OnAbility" target="Character" disabledeltatime="true" multiplyafflictionsbymaxvitality="true">
                <Conditional IsBot="false" />
                <Affliction identifier="thirst" strength="0.02"/>
              </StatusEffect>
            </StatusEffects>
          </CharacterAbilityApplyStatusEffects>
        </Abilities>
      </AbilityGroupInterval>
    </Talent>
    
    <Talent name="Sleepy Europan" identifier="he-sleepyeuropan">
      <Icon texture="%ModDir:2954998725%/Content/UI/HE-IconsAtlas.png" sourcerect="0,504,119,119" origin="0.5,0.5"/>
      <Description tag="talentdescription.he-sleepyeuropan" />
      <AbilityGroupInterval interval="1.0">
        <Abilities>
          <CharacterAbilityApplyStatusEffects>
            <StatusEffects>
              <StatusEffect type="OnAbility" target="Character" disabledeltatime="true" multiplyafflictionsbymaxvitality="true">
                <Conditional IsBot="false" />
                <Affliction identifier="fatigue" amount="0.012" />
              </StatusEffect>
            </StatusEffects>
          </CharacterAbilityApplyStatusEffects>
        </Abilities>
      </AbilityGroupInterval>
    </Talent>
    
    <Talent name="Moody Europan" identifier="he-moodyeuropan">
      <Icon texture="%ModDir:2954998725%/Content/UI/HE-IconsAtlas.png" sourcerect="119,504,119,119" origin="0.5,0.5"/>
      <Description tag="talentdescription.he-moodyeuropan" />
      
      <!-- Attempt at adding a random craving every minute (only if mood is above a certain %) -->
      <AbilityGroupInterval interval="300.0">
        <Abilities>
          <CharacterAbilityApplyStatusEffects>
            <StatusEffects>
              <StatusEffect type="OnAbility" target="Character" interval="1" disabledeltatime="true" multiplyafflictionsbymaxvitality="true" comparison="and">
                <Conditional IsBot="false" />
                <Conditional mood="gte 10" />
                <Conditional he-hungryforhumanmeat="lt 20" />
                <Affliction identifier="trait_likes_friedfoods" probability="0.01" amount="1200" />
                <Affliction identifier="trait_likes_burgers" probability="0.01" amount="1200" />
                <Affliction identifier="trait_likes_hotdogs" probability="0.01" amount="1200" />
                <Affliction identifier="trait_likes_pizza" probability="0.01" amount="1200" />
                <Affliction identifier="trait_likes_filets" probability="0.01" amount="1200" />
                <Affliction identifier="trait_likes_roasts" probability="0.01" amount="1200" />
                <Affliction identifier="trait_likes_sandwiches" probability="0.01" amount="1200" />
                <Affliction identifier="trait_likes_omelettes" probability="0.01" amount="1200" />
                <Affliction identifier="trait_likes_soups" probability="0.01" amount="1200" />
                <Affliction identifier="trait_likes_salads" probability="0.01" amount="1200" />
                <Affliction identifier="trait_likes_sweets" probability="0.01" amount="1200" />
                <Affliction identifier="trait_likes_fruits" probability="0.01" amount="1200" />
                <Affliction identifier="trait_likes_pasta" probability="0.01" amount="1200" />                
                <Affliction identifier="trait_likes_beer" probability="0.01" amount="1200" />
                <Affliction identifier="trait_likes_rum" probability="0.01" amount="1200" />
                <Affliction identifier="trait_likes_whiskey" probability="0.01" amount="1200" />
                <Affliction identifier="trait_likes_tea" probability="0.01" amount="1200" />
                <Affliction identifier="trait_likes_cola" probability="0.01" amount="1200" />
              </StatusEffect>
            </StatusEffects>
          </CharacterAbilityApplyStatusEffects>
        </Abilities>
      </AbilityGroupInterval>
      
      <!-- passively apply mood -->
      <AbilityGroupInterval interval="5.0">
        <Abilities>
          <CharacterAbilityApplyStatusEffects>
            <StatusEffects>
              <StatusEffect type="OnAbility" target="Character" disabledeltatime="true" multiplyafflictionsbymaxvitality="true">
                <Conditional IsBot="false" />
                <Affliction identifier="mood" probability="1" amount="0.01" />
                <Affliction identifier="moodenabled" probability="1.0" amount="1.0" />
                <!-- applies 1 moodcooldown every second -->
                <Affliction identifier="moodcooldown" amount="5.0"/>
              </StatusEffect>
            </StatusEffects>
          </CharacterAbilityApplyStatusEffects>
        </Abilities>
      </AbilityGroupInterval>      
      <!-- random chance of mood if character is attacked -->
	    <AbilityGroupEffect abilityeffecttype="OnAttacked">
        <Conditions>
          <!-- when moodcooldown affliction reaches 100%, this can trigger. acts as a cooldown to prevent instant stress buildup from very fast attacks such as steam sprayer -->
          <AbilityConditionHasAffliction afflictionidentifier="moodcooldown" minimumpercentage="1.0"/>
        </Conditions>
        <Abilities>
          <CharacterAbilityApplyStatusEffects>
            <StatusEffects>
              <StatusEffect type="OnAbility" target="Character" disabledeltatime="true" multiplyafflictionsbymaxvitality="true">
                <Conditional IsBot="false" />
                <Affliction identifier="mood" probability="0.2" amount="3.0" />
                <ReduceAffliction identifier="moodcooldown" amount="100.0" />
              </StatusEffect>
            </StatusEffects>
          </CharacterAbilityApplyStatusEffects>
        </Abilities>
      </AbilityGroupEffect>
      <!-- random chance of mood if sub is attacked -->
	    <AbilityGroupEffect abilityeffecttype="AfterSubmarineAttacked">
        <Conditions>
          <AbilityConditionHasAffliction afflictionidentifier="moodcooldown" minimumpercentage="1.0"/>
        </Conditions>
        <Abilities>
          <CharacterAbilityApplyStatusEffects>
            <StatusEffects>
              <StatusEffect type="OnAbility" target="Character" disabledeltatime="true" multiplyafflictionsbymaxvitality="true">
                <Conditional IsBot="false" />
                <Affliction identifier="mood" probability="0.2" amount="3.0" />
                <ReduceAffliction identifier="moodcooldown" amount="100.0" />
              </StatusEffect>
            </StatusEffects>
          </CharacterAbilityApplyStatusEffects>
        </Abilities>
      </AbilityGroupEffect>

      <!-- Cure mood with music. Accumulates an affliction to simulate a cooldown to listening to music. The affliction deletes itself after a delay -->
      <AbilityGroupEffect abilityeffecttype="OnUseRangedWeapon">
        <Conditions>
          <AbilityConditionItem tags="instrument"/>
        </Conditions>
        <Abilities>
          <CharacterAbilityApplyStatusEffects>
            <StatusEffects>
              <StatusEffect type="OnAbility" target="NearbyCharacters" range="300" interval="1" disabledeltatime="true">
                <Conditional moodmusiccooldown="lt 30" />
                <Affliction identifier="moodmusiccooldown" amount="1" />
                <ReduceAffliction identifier="mood" amount="0.5" />
              </StatusEffect>
            </StatusEffects>
          </CharacterAbilityApplyStatusEffects>
        </Abilities>
      </AbilityGroupEffect>
      
