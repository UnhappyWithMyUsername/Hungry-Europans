    <Talent identifier="he-filthyeuropan">
      <Icon texture="%ModDir:2954998725%/Content/UI/HE-IconsAtlas.png" sourcerect="119,385,119,119" origin="0.5,0.5"/>
      <Description tag="talentdescription.he-filthyeuropan" />
      <AbilityGroupInterval interval="1.0">
        <Abilities>
          <CharacterAbilityApplyStatusEffects>
            <StatusEffects>
              <StatusEffect type="OnAbility" target="Character" disabledeltatime="true" multiplyafflictionsbymaxvitality="true">
                <Conditional IsBot="false" />
                <Affliction identifier="bladder" strength="0.01"/>
              </StatusEffect>
              <StatusEffect type="OnAbility" target="Character" disabledeltatime="true" multiplyafflictionsbymaxvitality="true">
                <Conditional IsBot="false" />
                <Affliction identifier="defecate" strength="0.01"/>
              </StatusEffect>
              <StatusEffect type="OnAbility" target="Character" disabledeltatime="true" multiplyafflictionsbymaxvitality="true">
                <Conditional IsBot="false" />
                <Affliction identifier="hygiene" strength="0.005"/>
              </StatusEffect>
            </StatusEffects>
          </CharacterAbilityApplyStatusEffects>
        </Abilities>
      </AbilityGroupInterval>
      
      <!-- % chance of looting blubber from monsters to make soap -->
      <AbilityGroupEffect abilityeffecttype="OnLootCharacter">
        <Conditions>
          <AbilityConditionCharacter targettype="Monster">
            <Conditional maxhealth="gt 25"/>
            <Conditional mass="gte 55"/>
            <Conditional ismachine="false" />
          </AbilityConditionCharacter>
          <AbilityConditionCharacterNotLooted identifier="blubberlooted"/>
          <AbilityConditionServerRandom randomchance="0.10" />
        </Conditions>
        <Abilities>
          <CharacterAbilityMarkAsLooted identifier="blubberlooted"/>
          <CharacterAbilityApplyStatusEffects>
            <StatusEffects>
              <StatusEffect type="OnAbility" target="UseTarget" spawnitemrandomly="true" >
                <SpawnItem identifiers="he-blubber" spawnposition="ThisInventory" />
              </StatusEffect>
            </StatusEffects>
          </CharacterAbilityApplyStatusEffects>
        </Abilities>
      </AbilityGroupEffect>
      <!-- loot guaranteed on abyssals -->
      <AbilityGroupEffect abilityeffecttype="OnLootCharacter">
        <Conditions>
          <AbilityConditionCharacter targettype="Monster">
            <Conditional maxhealth="gt 25"/>
            <Conditional mass="gte 2000"/>
            <Conditional ismachine="false" />
          </AbilityConditionCharacter>
          <AbilityConditionCharacterNotLooted identifier="blubberlootedabyssal"/>
          <AbilityConditionServerRandom randomchance="1" />
        </Conditions>
        <Abilities>
          <CharacterAbilityMarkAsLooted identifier="blubberlootedabyssal"/>
          <CharacterAbilityApplyStatusEffects>
            <StatusEffects>
              <StatusEffect type="OnAbility" target="UseTarget" spawnitemrandomly="true" >
                <SpawnItem identifiers="he-blubber" amount="3" spawnposition="ThisInventory" />
              </StatusEffect>
            </StatusEffects>
          </CharacterAbilityApplyStatusEffects>
        </Abilities>
      </AbilityGroupEffect>
    </Talent>
        
